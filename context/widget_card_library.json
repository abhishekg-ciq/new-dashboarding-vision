{
  "_meta": {
    "purpose": "Starter widget card library for the Add Widget catalog. Cards are question-led (titled by the question they answer), each resolving to one of 3 intents (scorecard | trend | breakdown). Shape is inferred from intent and overridable after placing. Metric count and dimension are parameters, not patterns.",
    "grounded_in": "9 real FDE-built CommerceIQ reports (AMZ Baby, Weekly Keyword HF/HA, Outdoor Monthly, Commercial Portfolio, KD FW LBB, Activity/Slime POS, SoV QBR, Writing Monthly, Bev Monthly)",
    "intents": {
      "scorecard": "Headline number(s). No time axis, no dimension split. Default shape: kpi_cards.",
      "trend": "Metric(s) over time. Default shape: line. Table shape = time_matrix (periods as columns).",
      "breakdown": "Metric(s) across a dimension's values. Default shape: bar (single metric) or table (multi-metric/hierarchical). Pie = single-metric composition shape."
    },
    "shapes": ["kpi_cards", "line", "bar", "stacked_bar", "table", "time_matrix", "pie"],
    "moments": ["monitor", "diagnose", "opportunity"],
    "topics": ["Sales & Traffic", "Digital Shelf", "Advertising", "Share of Voice", "Budget"],
    "rules": {
      "two_axis_max": "No card varies more than two of {metric, dimension, time}. A card needing all three is split into two cards or resolved by a drill.",
      "comparison_is_global": "YoY / vs-prior-period is a dashboard-level date control, NOT a per-widget toggle or a card variant.",
      "metric_count_is_param": "Multiple metrics in one card is a parameter set in edit-widget, not a separate card or intent.",
      "source_inferred": "Source is resolved from metric+grain by the semantic layer; never shown as a selection."
    }
  },

